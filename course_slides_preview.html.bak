" lang="zh-TW" data-marpit-pagination="33" style="--paginate:true;--theme:default;--style:@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&amp;display=swap')
;" data-marpit-pagination-total="39" data-size="16:9">
<h2 id="%E5%AE%8C%E6%95%B4%E5%9B%A0%E6%9E%9C%E9%8F%88%E5%9B%9E%E9%A1%A7">完整因果鏈回顧</h2>
<table>
<thead>
<tr>
<th>方法</th>
<th>核心問題</th>
<th>解法</th>
<th>環境</th>
<th>結果</th>
</tr>
</thead>
<tbody>
<tr>
<td><strong>BC</strong></td>
<td>有示範就夠了嗎？</td>
<td>監督學習模仿</td>
<td>Pendulum</td>
<td>-145（分佈內）</td>
</tr>
<tr>
<td><strong>Q-Learning</strong></td>
<td>RL 的基礎語言？</td>
<td>Bellman + ε-greedy</td>
<td>FrozenLake</td>
<td>收斂 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
<tr>
<td><strong>DQN</strong></td>
<td>無限狀態怎麼辦？</td>
<td>神經網路 + Replay + Target</td>
<td>CartPole</td>
<td>500 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
<tr>
<td><strong>DDPG</strong></td>
<td>連續動作怎麼辦？</td>
<td>Actor-Critic</td>
<td>Pendulum</td>
<td>-101.6 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
<tr>
<td><strong>TD3</strong></td>
<td>DDPG 為何不穩？</td>
<td>Twin Q + Delay + Noise</td>
<td>Pendulum</td>
<td>-119.8 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
<tr>
<td><strong>SAC</strong></td>
<td>如何自動探索？</td>
<td>最大熵 + 自動 α</td>
<td>Pendulum+LunarLander</td>
<td>-172 / 262 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
<tr>
<td><strong>PPO</strong></td>
<td>如何穩定更新？</td>
<td>Clip + On-policy</td>
<td>CartPole+LunarLander</td>
<td>500 / 284 <img class="emoji" draggable="false" alt="✅" src="https://cdn.jsdelivr.net/gh/jdecked/twemoji@17.0.2/assets/svg/2705.svg" data-marp-twemoji=""/></td>
</tr>
</tbody>
</table>
</section>
</foreignObject></svg><svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="34" data-paginate="true" data-theme="default" data-style="@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&amp;display=swap');
